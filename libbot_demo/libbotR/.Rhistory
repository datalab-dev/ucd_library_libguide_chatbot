#' Repeatedly prompt the user for a search query and return formatted results.
#' Intended for use in an interactive R session or development testing.
run_interactive_search <- function() {
repeat {
# Clear the console before each new query
cat("\014")
cat("To exit at any time, type 'exit' and press Enter.\n")
user_prompt <- readline(prompt = "[Enter your search prompt]: ")
# Exit condition after search prompt
if (tolower(trimws(user_prompt)) %in% c("exit", "")) {
cat("\nExiting search. Goodbye!\n")
break
}
repeat {
user_top_n_input <- readline(prompt = "[How many top matches would you like?]: ")
# Exit condition after top_n prompt
if (tolower(trimws(user_top_n_input)) %in% c("exit", "")) {
cat("\nExiting search. Goodbye!\n")
return(invisible(NULL))  # or break outer loop if preferred
}
user_top_n <- as.integer(user_top_n_input)
if (is.na(user_top_n) || user_top_n <= 0) {
cat("Please enter a valid positive number.\n")
} else {
break  # valid input, break inner loop
}
}
cat("\nSearching...\n\n")
return_top_matches(user_prompt, user_top_n)
}
}
run_interactive_search()
#' Repeatedly prompt the user for a search query and return formatted results.
#' Intended for use in an interactive R session or development testing.
run_interactive_search <- function() {
repeat {
# Do NOT clear the console at the top — wait until after results are shown
cat("To exit at any time, type 'exit' and press Enter.\n")
user_prompt <- readline(prompt = "[Enter your search prompt]: ")
# Exit condition
if (tolower(trimws(user_prompt)) %in% c("exit", "")) {
cat("\nExiting search. Goodbye!\n")
break
}
repeat {
user_top_n_input <- readline(prompt = "[How many top matches would you like?]: ")
# Exit condition after top_n prompt
if (tolower(trimws(user_top_n_input)) %in% c("exit", "")) {
cat("\nExiting search. Goodbye!\n")
return(invisible(NULL))
}
user_top_n <- as.integer(user_top_n_input)
if (is.na(user_top_n) || user_top_n <= 0) {
cat("Please enter a valid positive number.\n")
} else {
break
}
}
cat("\nSearching...\n\n")
return_top_matches(user_prompt, user_top_n)
# Wait so the user can read the results
readline(prompt = "\n[Press Enter to continue]")
# Clear the console AFTER results are shown
cat("\014")
}
}
run_interactive_search()
